rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return request.auth.token.email_verified == true; }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    
    function isAdmin() {
      let data = getUserData(request.auth.uid);
      return isSignedIn() && (
        (data != null && data.role == 'admin') || 
        request.auth.token.email == 'skriyad0131@gmail.com'
      );
    }

    function isTeacher() {
      let data = getUserData(request.auth.uid);
      return isSignedIn() && data != null && data.role == 'teacher';
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // Phone mappings for secure login lookup
    match /phone_mappings/{phone} {
      allow read, write: if true;
    }

    // Username mapping for uniqueness
    match /usernames/{username} {
      allow read, write: if true;
    }

    // Chat Rooms
    match /chatRooms/{roomId} {
      allow read, write: if true;
    }

    // Messages
    match /chatRooms/{roomId}/messages/{messageId} {
      allow read, write: if true;
    }

    // Discussions
    match /discussions/{discussionId} {
      allow read, write: if true;
    }

    // Notes
    match /notes/{noteId} {
      allow read, write: if true;
    }

    // Notices
    match /notices/{noticeId} {
      allow read, write: if true;
    }
  }
}
